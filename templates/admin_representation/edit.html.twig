{% extends 'base.html.twig' %}

{% block title %}Modifier une représentation{% endblock %}

{% block body %}

    <div class="container my-5">
        <div class="bg-white col-md-6 mx-auto p-4 border border-2 border-green rounded shadow">

            <h2 class="text-center mb-4">Modifier la représentation</h2>

            {{ include('admin_representation/_form.html.twig', {'button_label': 'Update'}) }}

            <div class="d-flex justify-content-center gap-2 mt-3">
                <a href="{{ path('app_admin_representation_index', {'id': representation.spectacle.id}) }}" class="btn btn-secondary">
                    Retour à la liste
                </a>
                {{ include('admin_representation/_delete_form.html.twig') }}
            </div>

        </div>
    </div>

{% endblock %}