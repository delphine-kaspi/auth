{% extends 'base.html.twig' %}

{% block title %}Représentations{% endblock %}
{% block h1 %}Toutes les représentations{% endblock %}

{% block body %}

<div class="admin-section">

    <div class="admin-section-header">
        <a href="{{ path('admin_dashboard') }}" class="btn-back">← Retour au dashboard</a>
    </div>

    {% if representations is empty %}
        <p class="text-muted text-center mt-4">Aucune représentation enregistrée.</p>
    {% else %}
        <div class="table-responsive">
            <table class="table-admin">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Spectacle</th>
                        <th>Artiste</th>
                        <th>Date</th>
                        <th>Heure</th>
                        <th>Salle</th>
                        <th>Prix</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for representation in representations %}
                        <tr>
                            <td>{{ representation.id }}</td>
                            <td>{{ representation.spectacle.titre }}</td>
                            <td>{{ representation.spectacle.artiste.prenom }} {{ representation.spectacle.artiste.nom }}</td>
                            <td>{{ representation.dateRepresentation|date('d/m/Y') }}</td>
                            <td>{{ representation.heureRepresentation|date('H:i') }}</td>
                            <td>{{ representation.salle.nom }}</td>
                            <td>{{ representation.prix }} €</td>
                            <td class="table-admin-actions">
                                <a href="{{ path('app_admin_representation_edit', {'id': representation.id}) }}" class="btn-admin-edit">Modifier</a>
                                <form method="post" action="{{ path('app_admin_representation_delete', {'id': representation.id}) }}" onsubmit="return confirm('Supprimer cette représentation ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ representation.id) }}">
                                    <button class="btn-admin-delete">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

</div>

{% endblock %}
