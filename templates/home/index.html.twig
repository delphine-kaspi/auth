{% extends "base.html.twig" %}

{% block description %}Kastone Productions — Comedy, Stand-Up et spectacle vivant à Paris.
{% endblock %}
{% block keywords %}stand-up, comedy, spectacle, paris, production, humoriste
{% endblock %}

{% block title %}Kastone Productions — À l'affiche
{% endblock %}
{# {% block h1 %}À l'affiche{% endblock %} #}

{% block stylesheets %}
	{{ parent() }}
	<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700;1,900&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet">
	<style>

	/* ── VARIABLES ── */:root
	{
		--cream: #F5EDD6;
		--dark: #1C1208;
		--red: #C13020;
		--gold: #C8963C;
		--pale: #EAE0C4;
		--mid: #2E1F0A;
	}

	body {
		background: var(--cream);
		font-family: 'Crimson Pro', serif;
		color: var(--dark);
	}

	/* ── HERO ── */
	.ks-hero {
		background: var(--dark);
		position: relative;
		overflow: hidden;
		padding: 100px 24px 70px;
		text-align: center;
	}

	/* Arches décoratives */
	.ks-hero__arch {
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
		border: 1.5px solid rgba(200, 150, 60, 0.15);
		border-radius: 50% 50% 0 0;
		pointer-events: none;
	}
	.ks-hero__arch--1 {
		width: min(1100px, 160vw);
		height: min(550px, 80vw);
		top: -60px;
	}
	.ks-hero__arch--2 {
		width: min(820px, 120vw);
		height: min(410px, 60vw);
		top: -20px;
	}
	.ks-hero__arch--3 {
		width: min(560px, 90vw);
		height: min(280px, 45vw);
		top: 20px;
	}

	/* Points décoratifs */
	.ks-hero__dots {
		position: absolute;
		width: 160px;
		height: 260px;
		background-image: radial-gradient(circle, rgba(200,150,60,0.22) 1.5px, transparent 1.5px);
		background-size: 18px 18px;
		pointer-events: none;
	}
	.ks-hero__dots--left {
		left: 0;
		top: 50%;
		transform: translateY(-50%);
		mask-image: linear-gradient(to right, black, transparent);
	}
	.ks-hero__dots--right {
		right: 0;
		bottom: 60px;
		mask-image: linear-gradient(to left, black, transparent);
	}

	.ks-hero__inner {
		position: relative;
		z-index: 2;
	}

	.ks-hero__pretitle {
		font-size: 0.68rem;
		letter-spacing: 0.45em;
		text-transform: uppercase;
		color: var(--gold);
		margin-bottom: 6px;
	}

	.ks-hero__ornament {
		color: var(--gold);
		font-size: 1.2rem;
		letter-spacing: 0.3em;
		opacity: .6;
		margin: 6px 0 14px;
	}

	.ks-hero__title {
		font-family: 'Playfair Display', serif;
		font-size: clamp(3.5rem, 9vw, 9rem);
		font-weight: 900;
		line-height: .88;
		color: var(--cream);
		text-transform: uppercase;
		letter-spacing: -0.02em;
		margin: 0;
	}

	.ks-hero__title em {
		font-style: italic;
		font-weight: 400;
		color: var(--gold);
		display: block;
		font-size: 0.48em;
		letter-spacing: 0.06em;
		line-height: 1.7;
		margin-bottom: 4px;
	}

	.ks-hero__title .ks-hero__sub {
		display: block;
		font-size: 0.21em;
		font-weight: 400;
		font-style: normal;
		letter-spacing: 0.42em;
		text-transform: uppercase;
		color: rgba(245, 237, 214, .38);
		margin-top: 18px;
	}

	.ks-hero__rule {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 14px;
		margin: 26px auto;
		max-width: 400px;
	}
	.ks-hero__rule span {
		flex: 1;
		height: 1px;
		background: var(--gold);
		opacity: .3;
	}
	.ks-hero__rule i {
		color: var(--gold);
		font-style: normal;
		opacity: .5;
	}

	.ks-hero__desc {
		color: rgba(245, 237, 214, .55);
		font-size: 1.05rem;
		font-style: italic;
		line-height: 1.8;
		max-width: 480px;
		margin: 0 auto 36px;
	}

	.ks-hero__cta {
		display: flex;
		gap: 14px;
		justify-content: center;
		flex-wrap: wrap;
	}

	.ks-btn-red {
		background: var(--red);
		color: var(--cream);
		border: none;
		padding: 13px 36px;
		font-family: 'Playfair Display', serif;
		font-variant: small-caps;
		font-size: 0.9rem;
		letter-spacing: 0.15em;
		cursor: pointer;
		transition: background 0.3s, transform 0.2s;
		text-decoration: none;
		display: inline-block;
	}
	.ks-btn-red:hover {
		background: #a02010;
		transform: translateY(-2px);
		color: var(--cream);
	}

	.ks-btn-gold {
		background: transparent;
		color: var(--gold);
		border: 1px solid var(--gold);
		padding: 13px 36px;
		font-family: 'Playfair Display', serif;
		font-variant: small-caps;
		font-size: 0.9rem;
		letter-spacing: 0.15em;
		cursor: pointer;
		transition: background 0.3s, transform 0.2s;
		text-decoration: none;
		display: inline-block;
	}
	.ks-btn-gold:hover {
		background: rgba(200, 150, 60, .1);
		transform: translateY(-2px);
		color: var(--gold);
	}

	/* ── BANDEAU ── */
	.ks-band {
		background: var(--gold);
		padding: 12px 0;
		display: flex;
		justify-content: center;
		gap: 24px;
		flex-wrap: wrap;
		font-family: 'Playfair Display', serif;
		font-size: 0.72rem;
		letter-spacing: 0.2em;
		font-variant: small-caps;
		color: var(--dark);
		border-top: 2px solid rgba(28, 18, 8, .12);
	}
	.ks-band span {
		opacity: .4;
	}

	/* ── SECTION BASE ── */
	.ks-section {
		padding: 80px 24px;
	}
	.ks-section--dark {
		background: var(--dark);
		color: var(--cream);
	}
	.ks-section--mid {
		background: var(--mid);
		color: var(--cream);
	}

	.ks-section__header {
		text-align: center;
		margin-bottom: 56px;
	}

	.ks-section__pretitle {
		font-size: 0.68rem;
		letter-spacing: 0.42em;
		text-transform: uppercase;
		margin-bottom: 8px;
	}
	.ks-section--dark .ks-section__pretitle,
	.ks-section--mid .ks-section__pretitle {
		color: var(--gold);
	}
	.ks-section__pretitle {
		color: var(--red);
	}

	.ks-section__title {
		font-family: 'Playfair Display', serif;
		font-size: clamp(2rem, 4vw, 3.2rem);
		font-weight: 900;
		text-transform: uppercase;
		line-height: 1;
		letter-spacing: -0.01em;
		margin: 0;
	}

	.ks-section__rule {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 14px;
		margin: 16px auto 0;
		max-width: 280px;
	}
	.ks-section__rule span {
		flex: 1;
		height: 1px;
		background: var(--gold);
		opacity: .4;
	}
	.ks-section__rule i {
		color: var(--gold);
		font-style: normal;
		opacity: .5;
	}

	/* ── ARTISTES ── */

	/* Grille desktop */
	.ks-artists-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 20px;
		max-width: 1200px;
		margin: 0 auto;
	}

	@media(max-width: 767px) {
		.ks-artists-grid {
			display: none;
		}
	}

	/* Carousel mobile */
	.ks-artists-carousel {
		display: none;
	}
	@media(max-width: 767px) {
		.ks-artists-carousel {
			display: block;
		}
	}

	/* Carte artiste */
	.ks-artist-card {
		background: var(--dark);
		position: relative;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		transition: transform 0.3s;
	}
	.ks-artist-card:hover {
		transform: translateY(-4px);
	}

	.ks-artist-card::before {
		content: '';
		position: absolute;
		inset: 10px;
		border: 1px solid rgba(200, 150, 60, .15);
		pointer-events: none;
		z-index: 1;
		transition: border-color 0.3s;
	}
	.ks-artist-card:hover::before {
		border-color: rgba(200, 150, 60, .4);
	}

	.ks-artist-card__img {
		width: 100%;
		height: 240px;
		object-fit: cover;
		object-position: top;
		display: block;
		filter: grayscale(20%) sepia(10%);
		transition: filter 0.3s;
	}
	.ks-artist-card:hover .ks-artist-card__img {
		filter: grayscale(0%) sepia(0%);
	}

	.ks-artist-card__img-placeholder {
		width: 100%;
		height: 240px;
		background: rgba(255, 255, 255, .04);
		display: flex;
		align-items: center;
		justify-content: center;
		color: rgba(245, 237, 214, .2);
		font-style: italic;
		font-size: 0.85rem;
	}

	.ks-artist-card__body {
		padding: 24px 28px 28px;
		display: flex;
		flex-direction: column;
		flex: 1;
		position: relative;
		z-index: 2;
	}

	.ks-artist-card__num {
		position: absolute;
		top: 10px;
		right: 18px;
		font-family: 'Playfair Display', serif;
		font-size: 3.5rem;
		font-weight: 900;
		color: rgba(200, 150, 60, .07);
		line-height: 1;
		pointer-events: none;
	}

	.ks-artist-card__genre {
		font-size: 0.62rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--red);
		margin-bottom: 8px;
	}

	.ks-artist-card__name {
		font-family: 'Playfair Display', serif;
		font-size: 1.5rem;
		font-weight: 900;
		color: var(--cream);
		line-height: 1.1;
		margin-bottom: 10px;
	}

	.ks-artist-card__bio {
		font-size: 0.85rem;
		line-height: 1.7;
		color: rgba(245, 237, 214, .45);
		font-style: italic;
		flex: 1;
		margin-bottom: 20px;
	}

	.ks-artist-card__cta {
		background: var(--red);
		color: white;
		border: none;
		padding: 10px 20px;
		font-family: 'Playfair Display', serif;
		font-variant: small-caps;
		font-size: 0.85rem;
		letter-spacing: 0.12em;
		cursor: pointer;
		text-align: center;
		text-decoration: none;
		display: block;
		transition: background 0.3s;
	}
	.ks-artist-card__cta:hover {
		background: #a02010;
		color: white;
	}

	/* Carousel mobile controls */
	.ks-artists-carousel .carousel-control-prev-icon,
	.ks-artists-carousel .carousel-control-next-icon {
		filter: invert(0%);
		background-color: var(--gold);
		border-radius: 50%;
		padding: 18px;
		background-size: 50%;
	}

	/* ── SPECTACLES ── */
	.ks-shows-list {
		max-width: 860px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.ks-show-item {
		display: grid;
		grid-template-columns: 90px 1fr auto;
		align-items: center;
		gap: 24px;
		padding: 22px 28px;
		background: rgba(255, 255, 255, .03);
		border: 1px solid rgba(200, 150, 60, .1);
		position: relative;
		overflow: hidden;
		transition: background 0.3s, border-color 0.3s;
		cursor: pointer;
	}

	@media(max-width: 600px) {
		.ks-show-item {
			grid-template-columns: 70px 1fr;
			gap: 16px;
		}
		.ks-show-item__right {
			display: none;
		}
	}

	.ks-show-item::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0;
		bottom: 0;
		width: 3px;
		background: var(--gold);
		transform: scaleY(0);
		transform-origin: bottom;
		transition: transform 0.3s;
	}
	.ks-show-item:hover {
		background: rgba(200, 150, 60, .07);
		border-color: rgba(200, 150, 60, .3);
	}
	.ks-show-item:hover::before {
		transform: scaleY(1);
	}

	.ks-show-item__date {
		text-align: center;
	}

	.ks-show-item__day {
		font-family: 'Playfair Display', serif;
		font-size: 2rem;
		font-weight: 900;
		color: var(--gold);
		line-height: 1;
	}

	.ks-show-item__month {
		font-size: 0.6rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: rgba(245, 237, 214, .35);
		margin-top: 2px;
	}

	.ks-show-item__title {
		font-family: 'Playfair Display', serif;
		font-size: 1.35rem;
		font-weight: 700;
		margin-bottom: 4px;
	}

	.ks-show-item__meta {
		font-size: 0.82rem;
		color: rgba(245, 237, 214, .45);
		font-style: italic;
	}
	.ks-show-item__meta strong {
		color: rgba(245, 237, 214, .7);
		font-style: normal;
	}

	.ks-show-item__right {
		text-align: right;
	}

	.ks-show-item__type {
		display: inline-block;
		border: 1px solid rgba(200, 150, 60, .4);
		color: var(--gold);
		font-size: 0.58rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		padding: 3px 9px;
		margin-bottom: 8px;
	}

	.ks-show-item__cta {
		display: block;
		background: var(--red);
		color: white;
		border: none;
		padding: 7px 18px;
		font-family: 'Playfair Display', serif;
		font-variant: small-caps;
		font-size: 0.8rem;
		letter-spacing: 0.1em;
		cursor: pointer;
		text-align: center;
		text-decoration: none;
		transition: background 0.3s;
	}
	.ks-show-item__cta:hover {
		background: #a02010;
		color: white;
	}
	.ks-show-item__cta--full {
		background: rgba(255, 255, 255, .08);
		color: rgba(245, 237, 214, .35);
		cursor: default;
	}
	.ks-show-item__cta--full:hover {
		background: rgba(255, 255, 255, .08);
		color: rgba(245, 237, 214, .35);
	}

	/* ── À PROPOS ── */
	.ks-about {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 72px;
		max-width: 1100px;
		margin: 0 auto;
		align-items: center;
	}

	@media(max-width: 900px) {
		.ks-about {
			grid-template-columns: 1fr;
			gap: 40px;
		}
	}

	.ks-about__text p {
		font-size: 1.05rem;
		line-height: 1.9;
		color: rgba(245, 237, 214, .65);
		margin-bottom: 18px;
	}
	.ks-about__text p:first-child {
		font-family: 'Playfair Display', serif;
		font-size: 1.35rem;
		font-style: italic;
		color: var(--gold);
		line-height: 1.6;
	}

	.ks-about__stats {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2px;
	}

	.ks-stat {
		background: rgba(255, 255, 255, .04);
		border: 1px solid rgba(200, 150, 60, .12);
		padding: 32px 24px;
		text-align: center;
	}

	.ks-stat__num {
		font-family: 'Playfair Display', serif;
		font-size: 3rem;
		font-weight: 900;
		color: var(--gold);
		line-height: 1;
		display: block;
	}

	.ks-stat__label {
		font-size: 0.68rem;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: rgba(245, 237, 214, .32);
		margin-top: 6px;
		display: block;
	}
</style>{% endblock %}{% block body %}

{# ── HERO ── #}
<section class="ks-hero">
	<div class="ks-hero__arch ks-hero__arch--1"></div>
	<div class="ks-hero__arch ks-hero__arch--2"></div>
	<div class="ks-hero__arch ks-hero__arch--3"></div>
	<div class="ks-hero__dots ks-hero__dots--left"></div>
	<div class="ks-hero__dots ks-hero__dots--right"></div>

	<div class="ks-hero__inner">
		<p class="ks-hero__pretitle">Paris · Comedy · Stand-Up</p>
		<div class="ks-hero__ornament">✦ ✦ ✦</div>
		<h1 class="ks-hero__title">
			<em>Bienvenue chez</em>
			Kastone
			<span class="ks-hero__sub">Production · Stand-Up · Spectacle Vivant</span>
		</h1>
		<div class="ks-hero__rule">
			<span></span>
			<i>❧</i>
			<span></span>
		</div>
		<p class="ks-hero__desc">
			On déniche les talents, on produit les shows, on allume les scènes parisiennes. Chaque soir, le rire en grand.
		</p>
		<div class="ks-hero__cta">
			<a href="#artistes" class="ks-btn-red">Voir les artistes</a>
			<a href="#spectacles" class="ks-btn-gold">Prochains spectacles</a>
		</div>
	</div>
</section>

{# ── BANDEAU ── #}
<div class="ks-band">
	<span>✦</span>
	Stand-Up
	<span>✦</span>
	One-Man Show
	<span>✦</span>
	Improvisation
	<span>✦✦</span>
	Scène Ouverte
	<span>✦</span>
</div>

{# ── ARTISTES ── #}
<section class="ks-section ks-section--dark" id="artistes">
	<div class="ks-section__header">
		<p class="ks-section__pretitle">La Troupe</p>
		<h2 class="ks-section__title">À l'affiche</h2>
		<div class="ks-section__rule">
			<span></span>
			<i>❧</i>
			<span></span>
		</div>
	</div>

	{# Grille — desktop uniquement #}
	<div class="ks-artists-grid">
		{% for artiste in artistes %}
			<div class="ks-artist-card">
				<div class="ks-artist-card__num">{{ loop.index|number_format(2, 0, '.', '0') }}</div>

				{% if artiste.photo %}
					<img src="{{ asset('images/' ~ artiste.photo) }}" class="ks-artist-card__img" alt="Photo de {{ artiste.prenom }} {{ artiste.nom }}">
				{% else %}
					<div class="ks-artist-card__img-placeholder">Pas de photo</div>
				{% endif %}

				<div class="ks-artist-card__body">
					<div class="ks-artist-card__genre">Stand-Up</div>
					<div class="ks-artist-card__name">{{ artiste.prenom }}
						{{ artiste.nom }}</div>
					<div class="ks-artist-card__bio">
						{{ artiste.bio|slice(0, 160) }}
						{% if artiste.bio|length > 160 %}…
						{% endif %}
					</div>
					<a href="{{ path('app_artiste_show', {'id': artiste.id}) }}" class="ks-artist-card__cta">
						Voir le profil
					</a>
				</div>
			</div>
		{% else %}
			<p style="color:rgba(245,237,214,.4); font-style:italic; text-align:center; grid-column:1/-1;">
				Aucun artiste pour le moment.
			</p>
		{% endfor %}
	</div>

	{# Carousel — mobile uniquement #}
	<div class="ks-artists-carousel" id="artistesCarousel">
		<div id="artistesCarouselInner" class="carousel slide" data-bs-ride="carousel">
			<div class="carousel-inner">
				{% set chunkedArtistes = artistes|batch(1) %}
				{% for chunk in chunkedArtistes %}
					<div class="carousel-item {% if loop.first %}active{% endif %}">
						{% for artiste in chunk %}
							<div class="ks-artist-card mx-auto" style="max-width:340px;">
								<div class="ks-artist-card__num">{{ (loop.revindex0 + loop.parent.loop.index0 * 1 + 1)|number_format(2, 0, '.', '0') }}</div>

								{% if artiste.photo %}
									<img src="{{ asset('images/' ~ artiste.photo) }}" class="ks-artist-card__img" alt="Photo de {{ artiste.prenom }} {{ artiste.nom }}">
								{% else %}
									<div class="ks-artist-card__img-placeholder">Pas de photo</div>
								{% endif %}

								<div class="ks-artist-card__body">
									<div class="ks-artist-card__genre">Stand-Up</div>
									<div class="ks-artist-card__name">{{ artiste.prenom }}
										{{ artiste.nom }}</div>
									<div class="ks-artist-card__bio">
										{{ artiste.bio|slice(0, 160) }}
										{% if artiste.bio|length > 160 %}…
										{% endif %}
									</div>
									<a href="{{ path('app_artiste_show', {'id': artiste.id}) }}" class="ks-artist-card__cta">
										Voir le profil
									</a>
								</div>
							</div>
						{% endfor %}
					</div>
				{% endfor %}
			</div>

			<button class="carousel-control-prev" type="button" data-bs-target="#artistesCarouselInner" data-bs-slide="prev">
				<span class="carousel-control-prev-icon" aria-hidden="true"></span>
				<span class="visually-hidden">Précédent</span>
			</button>
			<button class="carousel-control-next" type="button" data-bs-target="#artistesCarouselInner" data-bs-slide="next">
				<span class="carousel-control-next-icon" aria-hidden="true"></span>
				<span class="visually-hidden">Suivant</span>
			</button>
		</div>
	</div>
</section>

{# ── SPECTACLES ── #}
<section class="ks-section" id="spectacles">
	<div class="ks-section__header">
		<p class="ks-section__pretitle" style="color:var(--red);">Agenda</p>
		<h2 class="ks-section__title">Prochains Spectacles</h2>
		<div class="ks-section__rule">
			<span></span>
			<i>❧</i>
			<span></span>
		</div>
	</div>

	<div class="ks-shows-list">
		{% set hasShows = false %}

		{% for spectacle in spectacles %}
			{% for rep in spectacle.representations %}
				{% set hasShows = true %}
				<div class="ks-show-item">

					<div class="ks-show-item__date">
						<div class="ks-show-item__day">{{ rep.dateRepresentation|date('d') }}</div>
						<div class="ks-show-item__month">{{ rep.dateRepresentation|date('M Y') }}</div>
					</div>

					<div>
						<div class="ks-show-item__title">{{ spectacle.titre }}</div>
						<div class="ks-show-item__meta">
							<strong>{{ spectacle.artiste.prenom }}
								{{ spectacle.artiste.nom }}</strong>
							{% if rep.salle is not null %}
								·
								{{ rep.salle.nom }},
								{{ rep.salle.ville }}
							{% endif %}
							·
							{{ rep.heureRepresentation|date('H:i') }}
						</div>
					</div>

					<div class="ks-show-item__right">
						<div class="ks-show-item__type">{{ rep.prix }}
							€</div>
						<a href="{{ path('app_spectacle_show', {'id': spectacle.id}) }}" class="ks-show-item__cta">
							Réserver
						</a>
					</div>

				</div>
			{% endfor %}
		{% endfor %}

		{% if not hasShows %}
			<p style="text-align:center; font-style:italic; color:rgba(28,18,8,.4); padding:40px 0;">
				Aucun spectacle programmé pour le moment.
			</p>
		{% endif %}
	</div>
</section>

{# ── À PROPOS ── #}
<section class="ks-section ks-section--mid" id="apropos">
	<div class="ks-section__header">
		<p class="ks-section__pretitle">Notre histoire</p>
		<h2 class="ks-section__title">Kastone Productions</h2>
		<div class="ks-section__rule">
			<span></span>
			<i>❧</i>
			<span></span>
		</div>
	</div>

	<div class="ks-about">
		<div class="ks-about__text">
			<p>Née d'une passion pour le rire et d'une conviction : les meilleurs humoristes méritent les meilleures scènes.</p>
			<p>
				Kastone Productions, c'est une boîte de production parisienne fondée par des passionnés de scène.
				        On accompagne les artistes de A à Z — de la première scène ouverte au one-man show en grande salle.
			</p>
			<p>
				Chaque spectacle qu'on produit est une histoire qu'on est fiers de raconter.
			</p>
			<a href="{{ path('app_contact') ?? '#' }}" class="ks-btn-red" style="margin-top:16px;">
				Travailler avec nous
			</a>
		</div>

		<div class="ks-about__stats">
			<div class="ks-stat">
				<span class="ks-stat__num">5</span>
				<span class="ks-stat__label">Ans d'existence</span>
			</div>
			<div class="ks-stat">
				<span class="ks-stat__num">{{ artistes|length }}+</span>
				<span class="ks-stat__label">Artistes produits</span>
			</div>
			<div class="ks-stat">
				<span class="ks-stat__num">200+</span>
				<span class="ks-stat__label">Spectacles organisés</span>
			</div>
			<div class="ks-stat">
				<span class="ks-stat__num">12</span>
				<span class="ks-stat__label">Salles partenaires</span>
			</div>
		</div>
	</div>
</section>{% endblock %}
