{% extends "base.html.twig" %}


{% block description %} {% endblock %}
{% block keywords %} {% endblock %}

{% block title %}Kastone Productions{% endblock %}
{% block h1 %}Nos spectacles{% endblock %}

{% block body %}
 
{# carousel #}

    <div id="carouselExample" class="carousel slide mb-5">
    <div class="carousel-inner">
        <div class="carousel-item active">
        <img src="{{ asset('images/felix_visuel.png')}}" class="d-block w-100" alt="...">
        </div>
        <div class="carousel-item">
        <img src="{{ asset('images/elies_visuel.jpg')}}" class="d-block w-100" alt="...">
        </div>
        <div class="carousel-item">
        <img src="{{ asset('images/meryl_visuel.jpeg')}}" class="d-block w-100" alt="...">
        </div>
        <div class="carousel-item">
        <img src="{{ asset('images/ayrton_visuel.jpg')}}" class="d-block w-100" alt="...">
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
    </div>

{% endblock %}
