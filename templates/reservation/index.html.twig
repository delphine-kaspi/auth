{% extends 'base.html.twig' %}

{% block title %}Réservation — Kastone Productions{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700;1,900&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet">
<style>
  :root { --cream:#F5EDD6; --dark:#1C1208; --red:#C13020; --gold:#C8963C; --mid:#2E1F0A; }
  body { background:var(--dark); font-family:'Crimson Pro',serif; color:var(--cream); }

  .ks-resa { min-height:calc(100vh - 62px); display:flex; align-items:center; justify-content:center; padding:60px 24px; position:relative; overflow:hidden; }

  .ks-resa__arch { position:absolute; left:50%; transform:translateX(-50%); border:1.5px solid rgba(200,150,60,.1); border-radius:50% 50% 0 0; pointer-events:none; }
  .ks-resa__arch--1 { width:min(1000px,160vw); height:min(500px,80vw); top:-60px; }
  .ks-resa__arch--2 { width:min(680px,120vw);  height:min(340px,60vw); top:-20px; }

  .ks-resa__inner { position:relative; z-index:2; max-width:560px; width:100%; }

  /* Infos spectacle */
  .ks-resa__info {
    text-align:center; margin-bottom:32px;
  }

  .ks-resa__pretitle { font-size:.68rem; letter-spacing:.42em; text-transform:uppercase; color:var(--gold); margin-bottom:8px; }
  .ks-resa__ornament { color:var(--gold); font-size:1.2rem; letter-spacing:.3em; opacity:.55; margin:6px 0 16px; }

  .ks-resa__show-title {
    font-family:'Playfair Display',serif; font-size:clamp(2rem,5vw,3.5rem);
    font-weight:900; color:var(--cream); text-transform:uppercase;
    line-height:.9; letter-spacing:-.02em; margin-bottom:10px;
  }

  .ks-resa__show-artiste {
    font-size:1rem; font-style:italic; color:rgba(245,237,214,.5);
  }

  .ks-resa__rule { display:flex; align-items:center; gap:14px; margin:20px auto; max-width:280px; }
  .ks-resa__rule span { flex:1; height:1px; background:var(--gold); opacity:.3; }
  .ks-resa__rule i { color:var(--gold); font-style:normal; opacity:.5; }

  /* Formulaire */
  .ks-resa__form {
    border:1px solid rgba(200,150,60,.2); padding:36px 40px; position:relative;
  }
  .ks-resa__form::before { content:''; position:absolute; inset:8px; border:1px solid rgba(200,150,60,.07); pointer-events:none; }

  .ks-resa__form label {
    display:block; font-size:.65rem; letter-spacing:.2em; text-transform:uppercase;
    color:rgba(245,237,214,.4); margin-bottom:8px;
  }

  .ks-resa__form input[type="number"] {
    width:100%; background:rgba(255,255,255,.05) !important;
    border:1px solid rgba(200,150,60,.2) !important; color:var(--cream) !important;
    padding:12px 16px !important; font-family:'Crimson Pro',serif !important;
    font-size:1.1rem !important; text-align:center; border-radius:0 !important;
    outline:none !important; transition:border-color .3s !important;
  }
  .ks-resa__form input[type="number"]:focus { border-color:var(--gold) !important; }

  .ks-btn-confirm {
    width:100%; background:var(--red); color:white; border:none;
    padding:14px 32px; font-family:'Playfair Display',serif;
    font-variant:small-caps; font-size:1rem; letter-spacing:.15em;
    cursor:pointer; margin-top:20px; transition:background .3s, transform .2s;
  }
  .ks-btn-confirm:hover { background:#a02010; transform:translateY(-2px); }

  /* Alert success */
  .ks-alert {
    background:rgba(200,150,60,.12); border:1px solid rgba(200,150,60,.3);
    color:var(--gold); padding:12px 18px; font-style:italic;
    font-size:.9rem; margin-bottom:20px; text-align:center;
  }
</style>
{% endblock %}

{% block body %}

<section class="ks-resa">
  <div class="ks-resa__arch ks-resa__arch--1"></div>
  <div class="ks-resa__arch ks-resa__arch--2"></div>

  <div class="ks-resa__inner">

    <div class="ks-resa__info">
      <p class="ks-resa__pretitle">Kastone Productions · Billetterie</p>
      <div class="ks-resa__ornament">✦ ✦ ✦</div>
      <h1 class="ks-resa__show-title">{{ representation.spectacle.titre }}</h1>
      <p class="ks-resa__show-artiste">
        {{ representation.spectacle.artiste.prenom }} {{ representation.spectacle.artiste.nom }}
        · {{ representation.dateRepresentation|date('d/m/Y') }}
        · {{ representation.heureRepresentation|date('H:i') }}
        · {{ representation.salle.nom }}
      </p>
      <div class="ks-resa__rule"><span></span><i>❧</i><span></span></div>
    </div>

    {% for message in app.flashes('success') %}
      <div class="ks-alert">✅ {{ message }}</div>
    {% endfor %}

    <div class="ks-resa__form">
      {{ form_start(form) }}
        {{ form_row(form.nbPlace, {
          'label': 'Nombre de places',
          'attr': {'min': 1}
        }) }}
        {{ form_widget(form.submit, {
          'label': 'Confirmer ma réservation',
          'attr': {'class': 'ks-btn-confirm'}
        }) }}
      {{ form_end(form) }}
    </div>

  </div>
</section>

{% endblock %}
