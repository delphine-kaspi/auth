{% extends 'base.html.twig' %}

{% block title %}Confirmation de réservation{% endblock %}
{% block h1 %}Confirmation de réservation{% endblock %}

{% block body %}

{% set representation = reservation.representation %}
{% set spectacle = representation.spectacle %}
{% set total = reservation.nbPlace * representation.prix %}

<div class="confirmation-card">

    <div class="confirmation-icon"></div>
    <p class="confirmation-msg">Votre réservation a bien été enregistrée !</p>

    <div class="recap-block">
        <h2>Récapitulatif</h2>

        <div class="recap-row">
            <span class="recap-label">Spectacle</span>
            <span class="recap-value">{{ spectacle.titre }}</span>
        </div>

        <div class="recap-row">
            <span class="recap-label">Artiste</span>
            <span class="recap-value">{{ spectacle.artiste }}</span>
        </div>

        <div class="recap-row">
            <span class="recap-label">Date</span>
            <span class="recap-value">{{ representation.dateRepresentation|date('d/m/Y') }}</span>
        </div>

        <div class="recap-row">
            <span class="recap-label">Heure</span>
            <span class="recap-value">{{ representation.heureRepresentation|date('H:i') }}</span>
        </div>

        <div class="recap-row">
            <span class="recap-label">Salle</span>
            <span class="recap-value">{{ representation.salle }}</span>
        </div>

        <div class="recap-row">
            <span class="recap-label">Nombre de places</span>
            <span class="recap-value">{{ reservation.nbPlace }}</span>
        </div>

        <div class="recap-row">
            <span class="recap-label">Prix unitaire</span>
            <span class="recap-value">{{ representation.prix }} €</span>
        </div>

        <div class="recap-row recap-total">
            <span class="recap-label">Total</span>
            <span class="recap-value">{{ total|number_format(2, ',', ' ') }} €</span>
        </div>
    </div>

    <div class="recap-row" style="margin-top: 1rem;">
        <span class="recap-label">Réservation effectuée le</span>
        <span class="recap-value">{{ reservation.dateResa|date('d/m/Y') }}</span>
    </div>

    <div class="confirmation-actions">
        <a href="{{ path('app_home') }}" class="btn btn-custom">Retour à l'accueil</a>
        <a href="{{ path('app_panier') }}" class="btn btn-custom">Voir mon panier</a>
    </div>

</div>

{% endblock %}
