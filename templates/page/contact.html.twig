{% extends 'base.html.twig' %}

{% block title %}Contact — Kastone Productions{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700;1,900&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet">
<style>
  :root { --cream:#F5EDD6; --dark:#1C1208; --red:#C13020; --gold:#C8963C; --mid:#2E1F0A; }
  body { background:var(--cream); font-family:'Crimson Pro',serif; color:var(--dark); }

  .ks-hero {
    background:var(--dark); position:relative; overflow:hidden;
    padding:90px 40px 70px; text-align:center;
  }
  .ks-hero__arch {
    position:absolute; left:50%; transform:translateX(-50%);
    border:1.5px solid rgba(200,150,60,.14); border-radius:50% 50% 0 0; pointer-events:none;
  }
  .ks-hero__arch--1 { width:min(1000px,160vw); height:min(500px,80vw); top:-60px; }
  .ks-hero__arch--2 { width:min(700px,120vw);  height:min(350px,60vw); top:-20px; }
  .ks-hero__inner { position:relative; z-index:2; }
  .ks-hero__pretitle { font-size:.68rem; letter-spacing:.42em; text-transform:uppercase; color:var(--gold); margin-bottom:8px; }
  .ks-hero__ornament { color:var(--gold); font-size:1.2rem; letter-spacing:.3em; opacity:.55; margin:6px 0 14px; }
  .ks-hero__title { font-family:'Playfair Display',serif; font-size:clamp(3rem,7vw,7rem); font-weight:900; line-height:.88; color:var(--cream); text-transform:uppercase; letter-spacing:-.02em; margin:0; }
  .ks-hero__title em { display:block; font-style:italic; font-weight:400; color:var(--gold); font-size:.45em; letter-spacing:.06em; line-height:1.7; margin-bottom:4px; }
  .ks-hero__rule { display:flex; align-items:center; justify-content:center; gap:14px; margin:22px auto; max-width:320px; }
  .ks-hero__rule span { flex:1; height:1px; background:var(--gold); opacity:.3; }
  .ks-hero__rule i { color:var(--gold); font-style:normal; opacity:.5; }
  .ks-hero__desc { font-size:1.05rem; font-style:italic; color:rgba(245,237,214,.55); max-width:480px; margin:0 auto; line-height:1.8; }

  .ks-band { background:var(--gold); padding:12px 0; display:flex; justify-content:center; gap:24px; flex-wrap:wrap;
    font-family:'Playfair Display',serif; font-size:.72rem; letter-spacing:.2em; font-variant:small-caps; color:var(--dark); }
  .ks-band span { opacity:.4; }

  .ks-section { padding:80px 40px; }
  .ks-section--dark { background:var(--dark); color:var(--cream); }

  /* CONTACT GRID */
  .ks-contact-grid {
    display:grid; grid-template-columns:1fr 1.4fr;
    gap:72px; max-width:1000px; margin:0 auto; align-items:start;
  }
  @media (max-width:768px) { .ks-contact-grid { grid-template-columns:1fr; gap:40px; } }

  .ks-contact-info h3 {
    font-family:'Playfair Display',serif; font-size:1.5rem; font-weight:700;
    color:var(--cream); margin-bottom:28px;
    padding-bottom:12px; border-bottom:1px solid rgba(200,150,60,.2);
  }

  .ks-contact-item {
    display:flex; gap:16px; align-items:flex-start;
    margin-bottom:22px; padding-bottom:22px;
    border-bottom:1px solid rgba(200,150,60,.08);
  }
  .ks-contact-item:last-child { border-bottom:none; margin-bottom:0; }

  .ks-contact-icon {
    width:38px; height:38px; flex-shrink:0;
    border:1px solid rgba(200,150,60,.35);
    display:flex; align-items:center; justify-content:center;
    color:var(--gold); font-size:.9rem;
  }

  .ks-contact-label {
    font-size:.62rem; letter-spacing:.2em; text-transform:uppercase;
    color:var(--red); margin-bottom:4px;
  }

  .ks-contact-value {
    font-size:.95rem; line-height:1.6; color:rgba(245,237,214,.65);
  }

  /* FORMULAIRE */
  .ks-form-wrap {
    border:1px solid rgba(200,150,60,.15); padding:40px 44px; position:relative;
  }
  .ks-form-wrap::before {
    content:''; position:absolute; inset:10px;
    border:1px solid rgba(200,150,60,.08); pointer-events:none;
  }

  .ks-form-wrap h3 {
    font-family:'Playfair Display',serif; font-size:1.5rem; font-weight:700;
    color:var(--cream); margin-bottom:28px;
    padding-bottom:12px; border-bottom:1px solid rgba(200,150,60,.2);
  }

  /* Override styles Bootstrap pour les champs du formulaire Symfony */
  .ks-form-wrap .form-group,
  .ks-form-wrap div { margin-bottom:18px; }

  .ks-form-wrap label {
    font-size:.65rem; letter-spacing:.2em; text-transform:uppercase;
    color:rgba(245,237,214,.45); display:block; margin-bottom:6px;
  }

  .ks-form-wrap input,
  .ks-form-wrap textarea,
  .ks-form-wrap select {
    width:100%;
    background:rgba(255,255,255,.05) !important;
    border:1px solid rgba(200,150,60,.2) !important;
    color:var(--cream) !important;
    padding:11px 16px !important;
    font-family:'Crimson Pro',serif !important;
    font-size:.95rem !important;
    outline:none !important;
    border-radius:0 !important;
    transition:border-color .3s !important;
  }

  .ks-form-wrap input:focus,
  .ks-form-wrap textarea:focus { border-color:var(--gold) !important; }

  .ks-form-wrap textarea { height:130px; resize:none; }

  .ks-form-wrap input::placeholder,
  .ks-form-wrap textarea::placeholder { color:rgba(245,237,214,.2) !important; }

  .ks-btn-submit {
    background:var(--red); color:white; border:none;
    padding:13px 36px; font-family:'Playfair Display',serif;
    font-variant:small-caps; font-size:.9rem; letter-spacing:.15em;
    cursor:pointer; transition:background .3s, transform .2s; margin-top:8px;
  }
  .ks-btn-submit:hover { background:#a02010; transform:translateY(-2px); }

  /* Alert success */
  .ks-alert-success {
    background:rgba(200,150,60,.12); border:1px solid rgba(200,150,60,.3);
    color:var(--gold); padding:14px 20px; font-style:italic;
    font-size:.95rem; margin-bottom:24px; text-align:center;
  }
</style>
{% endblock %}

{% block body %}

<section class="ks-hero">
  <div class="ks-hero__arch ks-hero__arch--1"></div>
  <div class="ks-hero__arch ks-hero__arch--2"></div>
  <div class="ks-hero__inner">
    <p class="ks-hero__pretitle">Kastone Productions · Paris</p>
    <div class="ks-hero__ornament">✦ ✦ ✦</div>
    <h1 class="ks-hero__title">
      <em>On se parle ?</em>
      Contact
    </h1>
    <div class="ks-hero__rule"><span></span><i>❧</i><span></span></div>
    <p class="ks-hero__desc">Une question, une candidature, une collaboration ? On vous répond avec plaisir.</p>
  </div>
</section>

<div class="ks-band">
  <span>✦</span> Stand-Up <span>✦</span> Comedy <span>✦</span> Paris <span>✦</span>
</div>

<section class="ks-section ks-section--dark">
  <div class="ks-contact-grid">

    {# Infos #}
    <div class="ks-contact-info">
      <h3>Nos coordonnées</h3>

      <div class="ks-contact-item">
        <div class="ks-contact-icon">✉</div>
        <div>
          <div class="ks-contact-label">Email</div>
          <div class="ks-contact-value">contact@kastone-productions.com</div>
        </div>
      </div>

      <div class="ks-contact-item">
        <div class="ks-contact-icon">☎</div>
        <div>
          <div class="ks-contact-label">Téléphone</div>
          <div class="ks-contact-value">06 02 03 04 05</div>
        </div>
      </div>

      <div class="ks-contact-item">
        <div class="ks-contact-icon">◈</div>
        <div>
          <div class="ks-contact-label">Adresse</div>
          <div class="ks-contact-value">21 rue des œillets<br>94140 Alfortville</div>
        </div>
      </div>

      <div class="ks-contact-item">
        <div class="ks-contact-icon">★</div>
        <div>
          <div class="ks-contact-label">Vous êtes artiste ?</div>
          <div class="ks-contact-value">Envoyez-nous votre dossier artistique, on étudie toutes les candidatures avec attention.</div>
        </div>
      </div>
    </div>

    {# Formulaire #}
    <div class="ks-form-wrap">
      <h3>Écrivez-nous</h3>

      {% for message in app.flashes('success') %}
        <div class="ks-alert-success">{{ message }}</div>
      {% endfor %}

      {{ form_start(form) }}
        {{ form_row(form.nom) }}
        {{ form_row(form.email) }}
        {{ form_row(form.contenu) }}
        <button type="submit" class="ks-btn-submit">Envoyer le message</button>
      {{ form_end(form) }}
    </div>

  </div>
</section>

{% endblock %}
