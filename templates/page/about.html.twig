{% extends 'base.html.twig' %}

{% block title %}À propos — Kastone Productions{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700;1,900&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet">
<style>
  :root { --cream:#F5EDD6; --dark:#1C1208; --red:#C13020; --gold:#C8963C; --mid:#2E1F0A; }
  body { background: var(--cream); font-family:'Crimson Pro',serif; color:var(--dark); }

  /* HERO */
  .ks-hero {
    background: var(--dark); position:relative; overflow:hidden;
    padding: 90px 40px 70px; text-align:center;
  }
  .ks-hero__arch {
    position:absolute; left:50%; transform:translateX(-50%);
    border:1.5px solid rgba(200,150,60,.14); border-radius:50% 50% 0 0; pointer-events:none;
  }
  .ks-hero__arch--1 { width:min(1000px,160vw); height:min(500px,80vw); top:-60px; }
  .ks-hero__arch--2 { width:min(700px,120vw);  height:min(350px,60vw); top:-20px; }
  .ks-hero__inner { position:relative; z-index:2; }
  .ks-hero__pretitle { font-size:.68rem; letter-spacing:.42em; text-transform:uppercase; color:var(--gold); margin-bottom:8px; }
  .ks-hero__ornament { color:var(--gold); font-size:1.2rem; letter-spacing:.3em; opacity:.55; margin:6px 0 14px; }
  .ks-hero__title {
    font-family:'Playfair Display',serif; font-size:clamp(3rem,7vw,7rem);
    font-weight:900; line-height:.88; color:var(--cream);
    text-transform:uppercase; letter-spacing:-.02em; margin:0;
  }
  .ks-hero__title em { display:block; font-style:italic; font-weight:400; color:var(--gold); font-size:.45em; letter-spacing:.06em; line-height:1.7; margin-bottom:4px; }
  .ks-hero__rule { display:flex; align-items:center; justify-content:center; gap:14px; margin:22px auto; max-width:320px; }
  .ks-hero__rule span { flex:1; height:1px; background:var(--gold); opacity:.3; }
  .ks-hero__rule i { color:var(--gold); font-style:normal; opacity:.5; }
  .ks-hero__desc { font-size:1.05rem; font-style:italic; color:rgba(245,237,214,.55); max-width:480px; margin:0 auto; line-height:1.8; }

  /* BANDEAU */
  .ks-band { background:var(--gold); padding:12px 0; display:flex; justify-content:center; gap:24px; flex-wrap:wrap;
    font-family:'Playfair Display',serif; font-size:.72rem; letter-spacing:.2em; font-variant:small-caps; color:var(--dark); }
  .ks-band span { opacity:.4; }

  /* SECTION */
  .ks-section { padding:80px 40px; }
  .ks-section--dark { background:var(--dark); color:var(--cream); }
  .ks-section--mid  { background:var(--mid);  color:var(--cream); }

  .ks-section__header { text-align:center; margin-bottom:52px; }
  .ks-section__pretitle { font-size:.68rem; letter-spacing:.42em; text-transform:uppercase; margin-bottom:8px; }
  .ks-section--dark .ks-section__pretitle,
  .ks-section--mid  .ks-section__pretitle { color:var(--gold); }
  .ks-section__pretitle { color:var(--red); }
  .ks-section__title { font-family:'Playfair Display',serif; font-size:clamp(2rem,4vw,3rem); font-weight:900; text-transform:uppercase; line-height:1; margin:0; }
  .ks-section__rule { display:flex; align-items:center; gap:14px; margin:14px auto 0; max-width:240px; }
  .ks-section__rule span { flex:1; height:1px; background:var(--gold); opacity:.4; }
  .ks-section__rule i { color:var(--gold); font-style:normal; opacity:.5; }

  /* TEXTE PRÉSENTATION */
  .ks-about-text {
    max-width:780px; margin:0 auto;
    border:1px solid rgba(200,150,60,.15); padding:48px 56px; position:relative;
  }
  .ks-about-text::before, .ks-about-text::after {
    content:''; position:absolute; width:20px; height:20px; border-color:var(--gold); border-style:solid; opacity:.5;
  }
  .ks-about-text::before { top:12px; left:12px; border-width:2px 0 0 2px; }
  .ks-about-text::after  { bottom:12px; right:12px; border-width:0 2px 2px 0; }

  .ks-about-text p {
    font-size:1.05rem; line-height:1.9; color:rgba(245,237,214,.65);
    margin-bottom:18px;
  }
  .ks-about-text p:first-child {
    font-family:'Playfair Display',serif; font-size:1.3rem; font-style:italic;
    color:var(--gold); line-height:1.6;
  }
  .ks-about-text p:last-child { margin-bottom:0; }

  /* ÉQUIPE */
  .ks-team-grid {
    display:grid; grid-template-columns:repeat(auto-fit, minmax(240px,1fr));
    gap:20px; max-width:900px; margin:0 auto;
  }

  .ks-team-card {
    background:var(--dark); position:relative; overflow:hidden;
    padding:40px 32px; text-align:center;
    transition:transform .3s;
  }
  .ks-team-card:hover { transform:translateY(-4px); }

  .ks-team-card::before {
    content:''; position:absolute; inset:10px;
    border:1px solid rgba(200,150,60,.15); pointer-events:none;
    transition:border-color .3s;
  }
  .ks-team-card:hover::before { border-color:rgba(200,150,60,.4); }

  .ks-team-card__img {
    width:90px; height:90px; border-radius:50%; object-fit:cover;
    border:2px solid rgba(200,150,60,.3); margin:0 auto 20px; display:block;
    filter:sepia(15%) grayscale(20%);
  }

  .ks-team-card__name {
    font-family:'Playfair Display',serif; font-size:1.3rem; font-weight:700;
    color:var(--cream); margin-bottom:6px;
  }

  .ks-team-card__role {
    font-size:.68rem; letter-spacing:.2em; text-transform:uppercase; color:var(--red);
  }

  .ks-team-card__ornament {
    color:var(--gold); opacity:.3; font-size:.9rem; letter-spacing:.3em; margin-top:16px;
  }
</style>
{% endblock %}

{% block body %}

{# HERO #}
<section class="ks-hero">
  <div class="ks-hero__arch ks-hero__arch--1"></div>
  <div class="ks-hero__arch ks-hero__arch--2"></div>
  <div class="ks-hero__inner">
    <p class="ks-hero__pretitle">Kastone Productions · Paris</p>
    <div class="ks-hero__ornament">✦ ✦ ✦</div>
    <h1 class="ks-hero__title">
      <em>Qui sommes-nous ?</em>
      À propos
    </h1>
    <div class="ks-hero__rule"><span></span><i>❧</i><span></span></div>
    <p class="ks-hero__desc">La passion du rire, l'exigence du spectacle vivant.</p>
  </div>
</section>

<div class="ks-band">
  <span>✦</span> Stand-Up <span>✦</span> One-Man Show <span>✦</span> Spectacle Vivant <span>✦</span>
</div>

{# PRÉSENTATION #}
<section class="ks-section ks-section--dark">
  <div class="ks-section__header">
    <p class="ks-section__pretitle">Notre histoire</p>
    <h2 class="ks-section__title">Kastone Productions</h2>
    <div class="ks-section__rule"><span></span><i>❧</i><span></span></div>
  </div>

  <div class="ks-about-text">
    <p>Kastone Productions est une compagnie de théâtre passionnée par la création et la diffusion de spectacles vivants.</p>
    <p>Depuis sa création, notre mission est de proposer des expériences uniques au public, alliant qualité artistique et accessibilité. Nous travaillons avec des artistes talentueux pour créer des pièces originales, des adaptations modernes et des collaborations innovantes.</p>
    <p>Que vous soyez spectateur régulier ou nouveau venu dans le monde du théâtre, nous vous invitons à découvrir notre univers et à partager des moments inoubliables avec nous.</p>
  </div>
</section>

{# ÉQUIPE #}
<section class="ks-section ks-section--mid">
  <div class="ks-section__header">
    <p class="ks-section__pretitle">Les visages</p>
    <h2 class="ks-section__title">Notre équipe</h2>
    <div class="ks-section__rule"><span></span><i>❧</i><span></span></div>
  </div>

  <div class="ks-team-grid">

    <div class="ks-team-card">
      <img src="{{ asset('images/logo3.png') }}" class="ks-team-card__img" alt="Thomas Escaffre Stone">
      <div class="ks-team-card__name">Thomas Escaffre Stone</div>
      <div class="ks-team-card__role">Grande directrice</div>
      <div class="ks-team-card__ornament">✦ ✦ ✦</div>
    </div>

    <div class="ks-team-card">
      <img src="{{ asset('images/logo3.png') }}" class="ks-team-card__img" alt="Zoé">
      <div class="ks-team-card__name">Zoé</div>
      <div class="ks-team-card__role">Adjointe</div>
      <div class="ks-team-card__ornament">✦ ✦ ✦</div>
    </div>

    <div class="ks-team-card">
      <img src="{{ asset('images/logo3.png') }}" class="ks-team-card__img" alt="Gianni">
      <div class="ks-team-card__name">Gianni</div>
      <div class="ks-team-card__role">Adjoint</div>
      <div class="ks-team-card__ornament">✦ ✦ ✦</div>
    </div>

  </div>
</section>

{% endblock %}
