{% extends 'base.html.twig' %}

{% block title %}Artistes
{% endblock %}
{% block h1 %}Mes Artistes
{% endblock %}

{% block body %}

	<div class="container my-5">
		<div class="bg-white col-md-10 mx-auto p-4 border border-2 border-green rounded shadow">
			<h2 class="text-center mb-4">Liste des artistes</h2>
			<div class="d-flex justify-content-end mb-3">
				<a href="{{ path('app_admin_artiste_new') }}" class="btn btn-custom">
					Ajouter un artiste
				</a>
			</div>
			<table class="table table-striped table-hover align-middle text-center">
				<thead class="table-dark">
					<tr>
						<th>Id</th>
						<th>Prénom</th>
						<th>Nom</th>
						<th>Photo</th>
						<th>Bio</th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					{% for artiste in artistes %}
						<tr>
							<td>{{ artiste.id }}</td>
							<td>{{ artiste.prenom }}</td>
							<td>{{ artiste.nom }}</td>
							<td>
								{% if artiste.photo %}
									<img src="{{ asset('images/' ~ artiste.photo) }}" width="80" class="rounded">
								{% else %}
									<span class="text-muted">Aucune photo</span>
								{% endif %}
							</td>
							<td>
								<a href="{{ path('app_admin_artiste_show', {'id': artiste.id}) }}" class="btn btn-sm btn-primary">Voir</a>
								<a href="{{ path('app_admin_artiste_edit', {'id': artiste.id}) }}" class="btn btn-sm btn-warning">Modifier</a>
								<a href="{{ path('app_admin_spectacle_index', {'id': artiste.id}) }}" class="btn btn-sm btn-warning">Spectacles</a>

							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="6" class="text-center">Aucun artiste pour le moment</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>

		</div>

	</div>

{% endblock %}
