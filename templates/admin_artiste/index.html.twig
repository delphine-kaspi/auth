{% extends 'base.html.twig' %}

{% block title %}Artistes{% endblock %}
{% block h1 %}Tous les artistes{% endblock %}

{% block body %}

<div class="admin-section">

    <div class="admin-section-header" style="display:flex; justify-content:space-between; align-items:center;">
        <a href="{{ path('admin_dashboard') }}" class="btn-back">← Retour au dashboard</a>
        <a href="{{ path('app_admin_artiste_new') }}" class="btn-admin-add" style="font-size:14px; padding: 7px 16px;">+ Nouvel.le artiste</a>
    </div>

    {% if artistes is empty %}
        <p class="text-muted text-center mt-4">Aucun artiste enregistré.</p>
    {% else %}
        <div class="table-responsive">
            <table class="table-admin">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Photo</th>
                        <th>Prénom</th>
                        <th>Nom</th>
                        <th>Bio</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for artiste in artistes %}
                        <tr>
                            <td>{{ artiste.id }}</td>
                            <td>
                                {% if artiste.photo %}
                                    <img src="{{ asset('images/' ~ artiste.photo) }}"
                                         width="60" height="60"
                                         style="object-fit:cover; border-radius:8px;">
                                {% else %}
                                    <span class="text-muted" style="font-size:12px;">Aucune photo</span>
                                {% endif %}
                            </td>
                            <td>{{ artiste.prenom }}</td>
                            <td><strong>{{ artiste.nom }}</strong></td>
                            <td style="max-width:260px; color:#666; font-size:13px;">
                                {{ artiste.bio|slice(0, 80) }}{% if artiste.bio|length > 80 %}…{% endif %}
                            </td>
                            <td class="table-admin-actions">
                                <a href="{{ path('app_admin_artiste_edit', {'id': artiste.id}) }}" class="btn-admin-edit">Modifier</a>
                                <a href="{{ path('app_admin_spectacle_new', {'id': artiste.id}) }}" class="btn-admin-add">+ Spectacle</a>
                                <form method="post" action="{{ path('app_admin_artiste_delete', {'id': artiste.id}) }}" onsubmit="return confirm('Supprimer cet artiste ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ artiste.id) }}">
                                    <button class="btn-admin-delete">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

</div>

{% endblock %}
