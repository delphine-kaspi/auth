{% extends 'base.html.twig' %}

{% block title %}Modifier la salle{% endblock %}
{% block h1 %}Modifier la salle{% endblock %}

{% block body %}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="admin-section-header">
                <a href="{{ path('app_admin_salle_index') }}" class="btn-back">← Retour aux salles</a>
            </div>

            <p class="admin-form-context">
                Modification de : <strong>{{ salle.nom }}</strong> — {{ salle.ville }}
            </p>

            <div class="bg-white col-md-6 mx-auto p-4 border border-2 border-green mb-5">
                {{ include('admin_salle/_form.html.twig', { button_label: 'Enregistrer les modifications' }) }}
            </div>

            <div style="max-width:600px; margin: 1rem auto 0 auto; text-align:right;">
                {{ include('admin_salle/_delete_form.html.twig') }}
            </div>

        </div>
    </div>
</div>

{% endblock %}