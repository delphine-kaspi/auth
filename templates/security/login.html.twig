{% extends 'base.html.twig' %}

{% block title %}Connexion — Kastone Productions{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700;1,900&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet">
<style>
  :root { --cream:#F5EDD6; --dark:#1C1208; --red:#C13020; --gold:#C8963C; --mid:#2E1F0A; }
  body { background:var(--dark); font-family:'Crimson Pro',serif; color:var(--cream); }

  .ks-auth { min-height:calc(100vh - 62px); display:flex; align-items:center; justify-content:center; padding:60px 24px; position:relative; overflow:hidden; }

  .ks-auth__arch { position:absolute; left:50%; transform:translateX(-50%); border:1.5px solid rgba(200,150,60,.1); border-radius:50% 50% 0 0; pointer-events:none; }
  .ks-auth__arch--1 { width:min(1000px,160vw); height:min(500px,80vw); top:-60px; }
  .ks-auth__arch--2 { width:min(680px,120vw);  height:min(340px,60vw); top:-20px; }

  .ks-auth__inner { position:relative; z-index:2; max-width:480px; width:100%; }

  .ks-auth__header { text-align:center; margin-bottom:32px; }
  .ks-auth__pretitle { font-size:.68rem; letter-spacing:.42em; text-transform:uppercase; color:var(--gold); margin-bottom:8px; }
  .ks-auth__ornament { color:var(--gold); font-size:1.2rem; letter-spacing:.3em; opacity:.55; margin:6px 0 14px; }
  .ks-auth__title { font-family:'Playfair Display',serif; font-size:clamp(2.5rem,5vw,4.5rem); font-weight:900; line-height:.9; color:var(--cream); text-transform:uppercase; letter-spacing:-.02em; margin:0; }
  .ks-auth__title em { display:block; font-style:italic; font-weight:400; color:var(--gold); font-size:.45em; letter-spacing:.06em; line-height:1.7; margin-bottom:4px; }
  .ks-auth__rule { display:flex; align-items:center; gap:14px; margin:20px auto; max-width:240px; }
  .ks-auth__rule span { flex:1; height:1px; background:var(--gold); opacity:.3; }
  .ks-auth__rule i { color:var(--gold); font-style:normal; opacity:.5; }

  /* Carte */
  .ks-auth__card { border:1px solid rgba(200,150,60,.2); padding:40px 44px; position:relative; }
  .ks-auth__card::before { content:''; position:absolute; inset:8px; border:1px solid rgba(200,150,60,.07); pointer-events:none; }

  /* Déjà connecté */
  .ks-auth__already {
    background:rgba(200,150,60,.08); border:1px solid rgba(200,150,60,.2);
    padding:14px 18px; margin-bottom:20px; font-size:.9rem; font-style:italic;
    color:rgba(245,237,214,.6); text-align:center;
  }
  .ks-auth__already a { color:var(--gold); text-decoration:none; }
  .ks-auth__already a:hover { text-decoration:underline; }

  /* Erreur */
  .ks-auth__error {
    background:rgba(193,48,32,.1); border:1px solid rgba(193,48,32,.3);
    color:var(--red); padding:12px 18px; font-style:italic;
    font-size:.88rem; margin-bottom:20px; text-align:center;
  }

  /* Champs */
  .ks-field { margin-bottom:18px; }

  .ks-field label {
    display:block; font-size:.65rem; letter-spacing:.2em; text-transform:uppercase;
    color:rgba(245,237,214,.4); margin-bottom:7px;
  }

  .ks-field label span { color:var(--red); }

  .ks-field input[type="email"],
  .ks-field input[type="password"],
  .ks-field input[type="text"] {
    width:100%; background:rgba(255,255,255,.05);
    border:1px solid rgba(200,150,60,.2); color:var(--cream);
    padding:12px 16px; font-family:'Crimson Pro',serif;
    font-size:.98rem; outline:none;
    transition:border-color .3s;
  }
  .ks-field input:focus { border-color:var(--gold); }
  .ks-field input::placeholder { color:rgba(245,237,214,.18); }

  /* Password wrapper */
  .ks-password-wrap { position:relative; }
  .ks-password-wrap input { padding-right:44px; }

  .ks-toggle-pwd {
    position:absolute; right:12px; top:50%; transform:translateY(-50%);
    background:none; border:none; color:rgba(245,237,214,.3); cursor:pointer;
    transition:color .3s; padding:0; line-height:0;
  }
  .ks-toggle-pwd:hover { color:var(--gold); }

  /* Remember me */
  .ks-remember {
    display:flex; align-items:center; gap:10px; margin:16px 0 20px;
  }
  .ks-remember input[type="checkbox"] { accent-color:var(--gold); width:16px; height:16px; flex-shrink:0; }
  .ks-remember label { font-size:.82rem; color:rgba(245,237,214,.45); cursor:pointer; }

  /* Bouton principal */
  .ks-btn-submit {
    width:100%; background:var(--red); color:white; border:none;
    padding:14px 32px; font-family:'Playfair Display',serif;
    font-variant:small-caps; font-size:1rem; letter-spacing:.15em;
    cursor:pointer; transition:background .3s, transform .2s;
  }
  .ks-btn-submit:hover { background:#a02010; transform:translateY(-2px); }

  /* Boutons secondaires */
  .ks-auth__links { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:12px; }

  .ks-btn-secondary {
    display:block; text-align:center; text-decoration:none;
    background:transparent; color:rgba(245,237,214,.45);
    border:1px solid rgba(200,150,60,.18);
    padding:10px 16px; font-family:'Playfair Display',serif;
    font-variant:small-caps; font-size:.78rem; letter-spacing:.1em;
    transition:border-color .3s, color .3s;
  }
  .ks-btn-secondary:hover { border-color:var(--gold); color:var(--gold); }

  /* Lien inscription */
  .ks-auth__register {
    text-align:center; margin-top:20px;
    font-size:.85rem; color:rgba(245,237,214,.3);
  }
  .ks-auth__register a { color:var(--gold); text-decoration:none; }
  .ks-auth__register a:hover { text-decoration:underline; }
</style>
{% endblock %}

{% block body %}

<section class="ks-auth">
  <div class="ks-auth__arch ks-auth__arch--1"></div>
  <div class="ks-auth__arch ks-auth__arch--2"></div>

  <div class="ks-auth__inner">

    <div class="ks-auth__header">
      <p class="ks-auth__pretitle">Kastone Productions · Mon compte</p>
      <div class="ks-auth__ornament">✦ ✦ ✦</div>
      <h1 class="ks-auth__title">
        <em>Bon retour</em>
        Connexion
      </h1>
      <div class="ks-auth__rule"><span></span><i>❧</i><span></span></div>
    </div>

    <div class="ks-auth__card">

      {# Déjà connecté #}
      {% if app.user %}
        <div class="ks-auth__already">
          Connecté en tant que <strong>{{ app.user.userIdentifier }}</strong> —
          <a href="{{ logout_path() }}">Déconnexion</a>
        </div>
      {% endif %}

      {# Erreur #}
      {% if error %}
        <div class="ks-auth__error">
          {% if error.line == 67 or error.line == 265 %}
            L'email ou le mot de passe est incorrect.
          {% else %}
            {{ error.messageKey|trans(error.messageData, 'security') }}
          {% endif %}
        </div>
      {% endif %}

      <form method="post">

        {# Email #}
        <div class="ks-field">
          <label for="inputEmail">Email <span>*</span></label>
          <input type="email" value="{{ last_username }}" name="email" id="inputEmail"
                 autocomplete="email" placeholder="votre@email.fr" required autofocus>
        </div>

        {# Mot de passe #}
        <div class="ks-field">
          <label for="inputPassword">Mot de passe <span>*</span></label>
          <div class="ks-password-wrap">
            <input type="password" name="password" id="inputPassword"
                   autocomplete="current-password" placeholder="••••••••" required>
            <button type="button" class="ks-toggle-pwd" onclick="togglePassword(this)" aria-label="Afficher/masquer">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
              </svg>
            </button>
          </div>
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        {# Remember me #}
        <div class="ks-remember">
          <input type="checkbox" name="_remember_me" id="remember">
          <label for="remember">Se souvenir de moi</label>
        </div>

        <button type="submit" class="ks-btn-submit">Se connecter</button>

        <div class="ks-auth__links">
          <a href="{{ path('app_register') }}" class="ks-btn-secondary">S'inscrire</a>
          <a href="{{ path('app_forgot_password_request') }}" class="ks-btn-secondary">Mot de passe oublié</a>
        </div>

      </form>
    </div>

    <p class="ks-auth__register">
      Pas encore de compte ? <a href="{{ path('app_register') }}">S'inscrire</a>
    </p>

  </div>
</section>

{% endblock %}

{% block javascripts %}
<script>
  function togglePassword(btn) {
    const input = btn.parentElement.querySelector('input');
    const isPassword = input.type === 'password';
    input.type = isPassword ? 'text' : 'password';
    btn.style.color = isPassword ? '#C8963C' : 'rgba(245,237,214,.3)';
  }
</script>
{% endblock %}
