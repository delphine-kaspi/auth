{% extends 'base.html.twig' %}

{% block title %}Mon panier{% endblock %}
{% block h1 %}Mes réservations à venir{% endblock %}

{% block body %}


<div class="panier-wrapper">

    {% if reservations is empty %}

        <div class="panier-empty">
            <p class="panier-empty-icon">🎭</p>
            <p class="panier-empty-msg">Vous n'avez aucune réservation à venir.</p>
            <a href="{{ path('app_home') }}" class="btn-confirmation">Découvrir les spectacles</a>
        </div>

    {% else %}

        {% set total_general = 0 %}

        {% for reservation in reservations %}
            {% set representation = reservation.representation %}
            {% set spectacle = representation.spectacle %}
            {% set total = reservation.nbPlace * representation.prix %}
            {% set total_general = total_general + total %}

            <div class="panier-card">
                <div class="panier-card-header">
                    <span class="panier-titre">{{ spectacle.titre }}</span>
                    <span class="panier-prix-total">{{ total|number_format(2, ',', ' ') }} €</span>
                </div>
                <div class="panier-card-body">
                    <div class="panier-row">
                        <span class="panier-label">Artiste</span>
                        <span class="panier-value">{{ spectacle.artiste }}</span>
                    </div>
                    <div class="panier-row">
                        <span class="panier-label">Date</span>
                        <span class="panier-value">{{ representation.dateRepresentation|date('d/m/Y') }}</span>
                    </div>
                    <div class="panier-row">
                        <span class="panier-label">Heure</span>
                        <span class="panier-value">{{ representation.heureRepresentation|date('H:i') }}</span>
                    </div>
                    <div class="panier-row">
                        <span class="panier-label">Salle</span>
                        <span class="panier-value">{{ representation.salle }}</span>
                    </div>
                    <div class="panier-row">
                        <span class="panier-label">Nombre de places</span>
                        <span class="panier-value">{{ reservation.nbPlace }}</span>
                    </div>
                    <div class="panier-row">
                        <span class="panier-label">Prix unitaire</span>
                        <span class="panier-value">{{ representation.prix }} €</span>
                    </div>
                    <div class="panier-row">
                        <span class="panier-label">Réservé le</span>
                        <span class="panier-value">{{ reservation.dateResa|date('d/m/Y à H:i') }}</span>
                    </div>
                    <div class="panier-row">
                        <p>Une confirmation vous sera envoyé sur votre adresse : <strong>{{ app.user.email }}</strong></p>
                    </div>
                </div>
            </div>

        {% endfor %}

        <div class="panier-total-general">
            <span>Total</span>
            <span>{{ total_general|number_format(2, ',', ' ') }} €</span>
        </div>

    {% endif %}

</div>

{% endblock %}
