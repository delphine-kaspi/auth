{{ form_start(form) }}

      {% for child in form %}
        {% if child.vars.name != 'save' %}
            {{ form_row(child, {'attr': {'class': 'form-control mb-2'}}) }}
        {% endif %}
        {% endfor %} 
    <button type="submit" class="btn btn-custom w-100 mt-3">
        {{ button_label|default('Enregistrer') }}
    </button>

{{ form_end(form) }}
