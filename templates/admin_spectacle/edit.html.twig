{% extends 'base.html.twig' %}

{% block title %}Modifier un spectacle{% endblock %}

{% block body %}

    <div class="container my-5">
        <div class="bg-white col-md-6 mx-auto p-4 border border-2 border-green rounded shadow">

            <h2 class="text-center mb-4">Modifier le spectacle</h2>

            {{ include('admin_spectacle/_form.html.twig', {'button_label': 'Mettre à jour'}) }}

            <div class="d-flex justify-content-center gap-2 mt-3">
                <a href="{{ path('app_admin_spectacle_index', {'id': spectacle.artiste.id}) }}" class="btn btn-secondary">
                    Retour à la liste
                </a>
                {{ include('admin_spectacle/_delete_form.html.twig') }}
            </div>

        </div>
    </div>

{% endblock %}