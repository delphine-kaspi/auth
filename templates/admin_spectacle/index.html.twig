{% extends 'base.html.twig' %}

{% block title %}Spectacles{% endblock %}
{% block h1 %}Tous les spectacles{% endblock %}

{% block body %}

<div class="admin-section">

    <div class="admin-section-header">
        <a href="{{ path('admin_dashboard') }}" class="btn-back">← Retour au dashboard</a>
        {# <a href="{{ path('app_admin_spectacle_new', {'id': categorie.id}) }}" class="btn-admin-add" style="font-size:14px; padding: 7px 16px;">+ Nouveau Spectacle</a> #}
    </div>

    {% if spectacles is empty %}
        <p class="text-muted text-center mt-4">Aucun spectacle enregistré.</p>
    {% else %}
        <div class="table-responsive">
            <table class="table-admin">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Titre</th>
                        <th>Artiste</th>
                        <th>Durée</th>
                        <th>Représentations</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for spectacle in spectacles %}
                        <tr>
                            <td>{{ spectacle.id }}</td>
                            <td>{{ spectacle.titre }}</td>
                            <td>{{ spectacle.artiste.prenom }} {{ spectacle.artiste.nom }}</td>
                            <td>{{ spectacle.duree }} min</td>
                            <td>{{ spectacle.representations|length }}</td>
                            <td class="table-admin-actions">
                                <a href="{{ path('app_admin_representation_new', {'id': spectacle.id}) }}" class="btn-admin-add">+ Représentation</a>
                                <a href="{{ path('app_admin_spectacle_edit', {'id': spectacle.id}) }}" class="btn-admin-edit">Modifier</a>
                                <form method="post" action="{{ path('app_admin_spectacle_delete', {'id': spectacle.id}) }}" onsubmit="return confirm('Supprimer ce spectacle ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ spectacle.id) }}">
                                    <button class="btn-admin-delete">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

</div>

{% endblock %}
